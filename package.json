{
  "name": "@tscircuit/high-density-a01",
  "module": "dist/index.js",
  "type": "module",
  "version": "0.0.4",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wasm": {
      "import": "./dist/wasm.js",
      "types": "./dist/wasm.d.ts"
    }
  },
  "scripts": {
    "start": "cosmos",
    "build:site": "bun run build && cosmos-export",
    "build:wasm": "cd wasm && wasm-pack build --target web --release",
    "build": "bun run build:wasm && tsup lib/index.ts lib/wasm.ts --dts --format esm && cp wasm/pkg/highdensity_solver_a01_wasm_bg.wasm dist/",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tscircuit/solver-utils": "^0.0.15",
    "@types/bun": "latest",
    "bun-match-svg": "^0.0.15",
    "graphics-debug": "^0.0.86",
    "react-cosmos": "^7.1.1",
    "react-cosmos-plugin-vite": "^7.1.1",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
